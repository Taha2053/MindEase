{
  "manifest_version": 3,
  "name": "MindEase",
  "version": "0.1.0",
  "description": "Learn the way your brain was meant to - AI-native adaptive learning extension",

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon-16.png",
      "48":  "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "downloads",
    "contextMenus"
  ],

  "host_permissions": [
    "<all_urls>",
    "https://api.mistral.ai/*"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "src/layer2/onboarding/onboarding.html",
        "src/session/dashboard/dashboard.html"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

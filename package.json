{
  "name": "mindease",
  "version": "0.1.0",
  "description": "AI-native browser extension for neurodiverse learners — GCD4F 2026",
  "scripts": {
    "dev:chrome": "vite --mode chrome",
    "dev:firefox": "vite --mode firefox",
